    {
      "name": "3. Pedidos",
      "item": [
        {
          "name": "Crear pedido (flujo completo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('pedidoId', jsonData.id);",
                  "    console.log('pedidoId guardado:', jsonData.id);",
                  "    console.log('Estado:', jsonData.estado);",
                  "    console.log('Total:', jsonData.total);",
                  "    console.log('Fecha creación:', jsonData.fechaCreacion);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": {{clienteId}},\n  \"productoId\": {{productoId}},\n  \"cantidad\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pedidos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pedidos"]
            }
          }
        },
        {
